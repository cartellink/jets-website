---
import '../styles/style.css';

interface Props {
  title: string;
  description?: string;
  activePage: 'home' | 'about' | 'programs' | 'gallery' | 'events' | 'contact';
}

const { title, description = "JETS Squash — Junior Emerging Talent in Sydney. Fun-first grassroots squash development at MAASH Sports & Fitness, Marsfield.", activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
</head>
<body>

  <a href="#main" class="skip-link">Skip to content</a>

  <header class="header" id="header">
    <div class="container header-inner">
      <a href="index.html" class="logo">
        <img src="/images/logo.png" alt="JETS Squash logo" width="48" height="48">
      </a>
      <nav class="nav" id="nav" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="index.html" class:list={["nav-link", { active: activePage === "home" }]}>Home</a></li>
          <li><a href="about.html" class:list={["nav-link", { active: activePage === "about" }]}>About</a></li>
          <li><a href="programs.html" class:list={["nav-link", { active: activePage === "programs" }]}>Programs</a></li>
          <li><a href="gallery.html" class:list={["nav-link", { active: activePage === "gallery" }]}>Gallery</a></li>
          <li><a href="events.html" class:list={["nav-link", { active: activePage === "events" }]}>Events</a></li>
          <li><a href="contact.html" class:list={["nav-link", { active: activePage === "contact" }]}>Contact</a></li>
        </ul>
      </nav>
      <a href="https://www.revolutionise.com.au/jetssquash/home" class="btn-primary nav-cta" target="_blank" rel="noopener">Join JETS</a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-col">
        <img src="/images/logo.png" alt="JETS Squash" class="footer-logo" width="40" height="40">
        <p>Junior Emerging Talent in Sydney.<br>Growing grassroots squash, one kid at a time.</p>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="index.html">Home</a></li>
          <li><a href="about.html">About</a></li>
          <li><a href="programs.html">Programs</a></li>
          <li><a href="gallery.html">Gallery</a></li>
          <li><a href="events.html">Events</a></li>
          <li><a href="contact.html">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Find Us</h4>
        <p>MAASH Sports &amp; Fitness<br>1 Trafalgar Pl, Marsfield NSW 2122</p>
        <div class="footer-socials">
          <a href="https://www.facebook.com/jetssquash" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
          <a href="https://www.revolutionise.com.au/jetssquash/home" target="_blank" rel="noopener">revolutioniseSPORT</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; 2026 JETS Squash. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script is:inline src="/js/main.js"></script>
</body>
</html>
