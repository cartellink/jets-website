---
import { asset } from '../utils';

interface Props {
  image: string;
  imageAlt: string;
  title: string;
  description: string;
  linkText?: string;
  linkHref?: string;
}
const { image, imageAlt, title, description, linkText, linkHref } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const resolvedLinkHref = linkHref && !linkHref.startsWith('http') ? `${base}${linkHref}` : linkHref;
---
<div class="card">
  <img src={asset(image)} alt={imageAlt}>
  <div class="card-body">
    <h3>{title}</h3>
    <p>{description}</p>
    {linkText && resolvedLinkHref && <a href={resolvedLinkHref}>{linkText}</a>}
  </div>
</div>
