---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="JETS Squash — Where Sydney's Future Squash Stars Begin" activePage="home">

    <!-- Hero -->
    <section class="hero fade-in" style="background-image: url(/images/banner.jpg)">
      <div class="hero-overlay"></div>
      <div class="container">
        <div class="hero-content">
          <h1>Where Sydney's Future Squash Stars Begin</h1>
          <p>Fun-first junior squash development in Marsfield</p>
          <a href="contact.html" class="btn-primary">Come Try a Session</a>
        </div>
      </div>
    </section>

    <!-- Stats strip -->
    <div class="stats-strip fade-in">
      <div class="container">
        <div class="stat">
          <strong>7 Courts</strong>
          <span>at MAASH Sports &amp; Fitness</span>
        </div>
        <div class="stat">
          <strong>Monthly Comps</strong>
          <span>Skill-based competitions every month</span>
        </div>
        <div class="stat">
          <strong>All Welcome</strong>
          <span>Every age, every level</span>
        </div>
      </div>
    </div>

    <!-- What is JETS -->
    <section class="section fade-in">
      <div class="container">
        <div class="split">
          <div class="split-text">
            <p class="label">ABOUT US</p>
            <h2>Growing the Game, One Kid at a Time</h2>
            <p>JETS Squash is a grassroots squash development program dedicated to nurturing junior talent in Sydney. Built on a fun-first philosophy, we believe every child deserves the chance to discover the joy of squash — regardless of experience or ability. Founded by Geoff and Yan, JETS runs programs at MAASH Sports &amp; Fitness in Marsfield, offering a welcoming and energetic environment for players of all backgrounds.</p>
            <a href="about.html" class="btn-secondary">Learn More About Us</a>
          </div>
          <div class="split-image">
            <img src="/images/facebook/653955516_773336195844007_3682554097701585321_n.jpg" alt="Young player wearing JETS Squash shirt on court" class="img-rounded">
          </div>
        </div>
      </div>
    </section>

    <!-- Programs preview -->
    <section class="section fade-in">
      <div class="container">
        <p class="label label--blue">PROGRAMS</p>
        <h2>What We Offer</h2>
        <div class="card-grid">
          <div class="card">
            <img src="/images/facebook/473443356_447780278399602_94195473102618945_n.jpg" alt="Kids learning squash through balloon games">
            <div class="card-body">
              <h3>Junior Development</h3>
              <p>Fun activities and games-based learning for kids new to squash.</p>
              <a href="programs.html">Learn More &rarr;</a>
            </div>
          </div>
          <div class="card">
            <img src="/images/facebook/649116004_767413059769654_6412016940392393593_n.jpg" alt="Coach Geoff with junior players and trophies">
            <div class="card-body">
              <h3>Monthly Competitions</h3>
              <p>Skill-based comps every month — at least 3 games guaranteed.</p>
              <a href="programs.html">Learn More &rarr;</a>
            </div>
          </div>
          <div class="card">
            <img src="/images/facebook/646574231_763778120133148_5577528663225417962_n.jpg" alt="Junior player in competitive match">
            <div class="card-body">
              <h3>Tournaments</h3>
              <p>Annual JETS Junior Open and representative pathway events.</p>
              <a href="programs.html">Learn More &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Photo mosaic -->
    <section class="section fade-in">
      <div class="container">
        <h2>Our Community</h2>
        <div class="mosaic">
          <img src="/images/facebook/473140704_447780261732937_6967452162561479841_n.jpg" alt="Junior player celebrating on court">
          <img src="/images/facebook/646516396_763778290133131_6976107515536203217_n.jpg" alt="Junior player lunging for the ball on court">
          <img src="/images/facebook/648732357_767412976436329_6678313667816505612_n.jpg" alt="Coach Geoff with players at tournament">
          <img src="/images/facebook/473072185_447780295066267_5268909810549177595_n.jpg" alt="Young player celebrating victory">
          <img src="/images/facebook/649725241_767412913103002_7943332619203084515_n.jpg" alt="Junior JETS players group photo">
        </div>
      </div>
    </section>

    <!-- CTA banner -->
    <div class="cta-banner fade-in">
      <h2>Ready to Pick Up a Racquet?</h2>
      <p>No experience needed. Come along to a session and see what JETS is all about.</p>
      <a href="contact.html" class="btn-primary">Get in Touch</a>
    </div>

</BaseLayout>
