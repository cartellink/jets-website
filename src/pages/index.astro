---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsStrip from '../components/StatsStrip.astro';
import SplitSection from '../components/SplitSection.astro';
import Card from '../components/Card.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Section from '../components/Section.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<BaseLayout title="JETS Squash — Where Sydney's Future Squash Stars Begin" activePage="home">

    <Hero
      title="Where Sydney's Future Squash Stars Begin"
      subtitle="Fun-first junior squash development in Marsfield"
      backgroundImage="/images/banner.jpg"
      ctaText="Come Try a Session"
      ctaHref="contact.html"
    />

    <StatsStrip />

    <SplitSection image="/images/facebook/653955516_773336195844007_3682554097701585321_n.jpg" imageAlt="Young player wearing JETS Squash shirt on court">
      <p class="label">ABOUT US</p>
      <h2>Growing the Game, One Kid at a Time</h2>
      <p>JETS Squash is a grassroots squash development program dedicated to nurturing junior talent in Sydney. Built on a fun-first philosophy, we believe every child deserves the chance to discover the joy of squash — regardless of experience or ability. Founded by Geoff and Yan, JETS runs programs at MAASH Sports &amp; Fitness in Marsfield, offering a welcoming and energetic environment for players of all backgrounds.</p>
      <a href={`${base}about.html`} class="btn-secondary">Learn More About Us</a>
    </SplitSection>

    <Section>
      <p class="label label--blue">PROGRAMS</p>
      <h2>What We Offer</h2>
      <div class="card-grid">
        <Card
          image="/images/facebook/473443356_447780278399602_94195473102618945_n.jpg"
          imageAlt="Kids learning squash through balloon games"
          title="Junior Development"
          description="Fun activities and games-based learning for kids new to squash."
          linkText="Learn More →"
          linkHref="programs.html"
        />
        <Card
          image="/images/facebook/649116004_767413059769654_6412016940392393593_n.jpg"
          imageAlt="Coach Geoff with junior players and trophies"
          title="Monthly Competitions"
          description="Skill-based comps every month — at least 3 games guaranteed."
          linkText="Learn More →"
          linkHref="programs.html"
        />
        <Card
          image="/images/facebook/646574231_763778120133148_5577528663225417962_n.jpg"
          imageAlt="Junior player in competitive match"
          title="Tournaments"
          description="Annual JETS Junior Open and representative pathway events."
          linkText="Learn More →"
          linkHref="programs.html"
        />
      </div>
    </Section>

    <Section>
      <h2>Our Community</h2>
      <div class="mosaic">
        <img src="/images/facebook/473140704_447780261732937_6967452162561479841_n.jpg" alt="Junior player celebrating on court">
        <img src="/images/facebook/646516396_763778290133131_6976107515536203217_n.jpg" alt="Junior player lunging for the ball on court">
        <img src="/images/facebook/648732357_767412976436329_6678313667816505612_n.jpg" alt="Coach Geoff with players at tournament">
        <img src="/images/facebook/473072185_447780295066267_5268909810549177595_n.jpg" alt="Young player celebrating victory">
        <img src="/images/facebook/649725241_767412913103002_7943332619203084515_n.jpg" alt="Junior JETS players group photo">
      </div>
    </Section>

    <CtaBanner
      title="Ready to Pick Up a Racquet?"
      description="No experience needed. Come along to a session and see what JETS is all about."
      ctaText="Get in Touch"
      ctaHref="contact.html"
    />

</BaseLayout>
