---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
---
<BaseLayout title="Get Involved — JETS Squash" description="Get involved with JETS Squash — join us for a session, find our location at MAASH Sports & Fitness, and connect with the JETS community." activePage="contact">

    <Hero
      title="Get Involved"
      subtitle="Come be part of the JETS family"
      backgroundImage="/images/banner.jpg"
      small
    />

    <Section>
      <h2>Three Simple Steps</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Come Try a Session</h3>
          <p>No commitment, no experience needed. Just come along and have a hit. We'll lend you a racquet.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>Join JETS</h3>
          <p>Sign up through revolutioniseSPORT to become a member and access all our programs.</p>
          <a href="https://www.revolutionise.com.au/jetssquash/home" class="btn-primary" target="_blank" rel="noopener">Sign Up</a>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Play, Compete, Grow</h3>
          <p>From fun social sessions to monthly comps and state-level tournaments — your squash journey starts here.</p>
        </div>
      </div>
    </Section>

    <section class="section section--light fade-in">
      <div class="container">
        <div class="split">
          <div>
            <h2>Find Us</h2>
            <h3>MAASH Sports &amp; Fitness</h3>
            <p>1 Trafalgar Pl, Marsfield NSW 2122</p>
            <p>7 squash courts</p>
            <a href="https://maash.com.au" class="btn-secondary" target="_blank" rel="noopener">Visit MAASH Website</a>
          </div>
          <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3314.5!2d151.1!3d-33.77!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12afff8175ea55%3A0x21c42e44aaab9b5b!2sMaash%20Sports%20And%20Fitness!5e0!3m2!1sen!2sau!4v1" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="MAASH Sports and Fitness location"></iframe>
          </div>
        </div>
      </div>
    </section>

    <Section>
      <div style="text-align: center;">
        <h2>Connect With Us</h2>
        <div class="connect-links">
          <a href="https://www.facebook.com/jetssquash" class="connect-link" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
            <span>Follow us on Facebook</span>
          </a>
          <a href="https://www.revolutionise.com.au/jetssquash/home" class="connect-link" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <span>Join via revolutioniseSPORT</span>
          </a>
        </div>
      </div>
    </Section>

    <Section class="section--dark">
      <div style="text-align: center;">
        <h2>Support JETS</h2>
        <p>JETS Squash is a not-for-profit organisation. Your support helps us keep programs affordable and accessible for all kids.</p>
        <a href="https://asf.org.au/projects/nsw-squash-limited/jets-junior-squash-development" class="btn-primary" target="_blank" rel="noopener">Donate via Australian Sports Foundation</a>
      </div>
    </Section>

</BaseLayout>
